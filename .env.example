# OpenGradient AI SDK provider — environment variables
# Copy to `.env` and fill in. NEVER commit a real private key.

# REQUIRED. EVM private key (hex, with or without 0x prefix).
# The wallet pays for inference via x402 and must hold OPG on Base mainnet
# (run `ensureOpgApproval` once as a prerequisite — it sends on-chain txs).
OPENGRADIENT_PRIVATE_KEY=0x...

# OPTIONAL. Override the RPC URL used to query the on-chain TEE registry.
# Leave unset to use the SDK default OpenGradient RPC.
# OPENGRADIENT_RPC_URL=

# OPTIONAL. Override the deployed TEERegistry contract address.
# OPENGRADIENT_TEE_REGISTRY_ADDRESS=

# OPTIONAL. Hardcoded TEE LLM server URL(s) for dev / self-hosted use.
# When set, the on-chain TEE registry is bypassed and TLS pinning is disabled.
# Comma-separate multiple endpoints to fail over across them in order.
# OPENGRADIENT_LLM_SERVER_URL=https://13.59.207.188,https://3.15.214.21

# OPTIONAL. Max payment per request, in atomic units (USDC has 6 decimals).
# Defaults to the x402-fetch default of 100000 (= 0.10 USDC) when unset.
# OPENGRADIENT_MAX_PAYMENT_VALUE=100000
